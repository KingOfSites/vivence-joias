# Banco de dados (MySQL)
DATABASE_URL=mysql://usuario:senha@host:porta/nome_do_banco

# Mercado Pago - Checkout Pro
# Token em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=TEST-xxxx
# Chave secreta gerada no painel do MP em: Suas integrações > App > Webhooks > Salvar configuração
MP_WEBHOOK_SECRET=
# Chave pública (opcional, para SDK no front)
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-xxxx

# URL base do site (para links de retorno do pagamento)   
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth (JWT) - use um valor aleatório longo em produção
AUTH_SECRET=seu-secret-muito-seguro-aqui
